# Copy to .env.local and fill in values. Do not commit real keys.

# Supabase (required for cloud sync)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: only needed for server-side admin tasks (not required for MVP)
# SUPABASE_SERVICE_ROLE_KEY=

# OpenAI API key for server-side observation draft generation
OPENAI_API_KEY=

# Model used by /api/observation-draft (default: gpt-4o-mini)
OBSERVATION_DRAFT_MODEL=gpt-4o-mini
